# Copie para .env (dev) ou configure como variáveis de ambiente no Coolify (produção).

# Chave de sessão do Flask — gere uma aleatória e mantenha em segredo.
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-isto

# Chave para criptografar as senhas de e-mail dos usuários. NÃO mude depois de criar usuários
# (mudar invalida as senhas SMTP já salvas).
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# Banco. Em produção, o Coolify fornece a URL do Postgres (use a conexão INTERNA do serviço).
#   Ex.: postgresql+psycopg2://usuario:senha@nome-do-servico:5432/banco
# Se ficar vazio, o app usa um SQLite local (apenas para desenvolvimento).
DATABASE_URL=
